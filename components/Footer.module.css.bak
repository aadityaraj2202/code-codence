.footer {
    background: linear-gradient(135deg, #0a0e1a 0%, #111827 100%);
    color: #e5e7eb;
    padding: 3rem 0 1.5rem;
    margin-top: auto;
}

.footerContent {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.brandSection {
    max-width: 350px;
}

.brandName {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, #3b82f6 0%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.brandTagline {
    color: #9ca3af;
    font-size: 0.95rem;
    line-height: 1.6;
}

.linksSection {
    display: flex;
    flex-direction: column;
}

.linkTitle {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: #f3f4f6;
}

.linkList {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.linkList li a {
    color: #9ca3af;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s ease;
}

.linkList li a:hover {
    color: #3b82f6;
}

.copyright {
    text-align: center;
    padding-top: 1.5rem;
    color: #6b7280;
    font-size: 0.875rem;
}

/* Responsive Design */
@media (max-width: 1024px) {
    .footerContent {
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }
}

@media (max-width: 640px) {
    .footerContent {
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    .brandSection {
        max-width: 100%;
    }

    .footer {
        padding: 2rem 0 1rem;
    }
}

